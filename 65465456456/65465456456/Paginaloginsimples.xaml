<Page x:Class="_65465456456.Paginaloginsimples"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:_65465456456"
      mc:Ignorable="d" 
      d:DesignHeight="720" d:DesignWidth="1280"
      Title="Paginaloginsimples">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Canvas Grid.RowSpan="2">
            <Canvas.Background>
                <ImageBrush ImageSource="/fundo escola.png"/>

            </Canvas.Background>
            <Canvas>

                <Rectangle HorizontalAlignment="Left" Height="286" Stroke="Black" VerticalAlignment="Top" Width="342" Canvas.Left="134" Canvas.Top="261" Fill="White" RadiusX="16.001" RadiusY="16.001"/>
                <Image Source="C:\Users\VINICIUSDASILVASAGIO\Desktop\aleatorio2\testone\65465456456\logo escola.png" Canvas.Left="64" Canvas.Top="5" Height="334" Width="482" HorizontalAlignment="Center" VerticalAlignment="Top" />


            </Canvas>
            <TextBox x:Name="email_usuario" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="226" Height="28" Canvas.Left="193" Canvas.Top="326" Padding="35,0,0,0" GotFocus="email_usuario_GotFocus"
         LostFocus="email_usuario_LostFocus" HorizontalAlignment="Left"/>

            <Image Source="C:\Users\VINICIUSDASILVASAGIO\Desktop\aleatorio2\testone\65465456456\emaillogo.png" Height="23" Width="22" Canvas.Left="195" Canvas.Top="329" />
            <TextBlock x:Name="blockusuario" HorizontalAlignment="Left" TextWrapping="Wrap" Text="Email/Usuario" Opacity="0.5" FontSize="14" VerticalAlignment="Top"
               IsHitTestVisible="False" TextAlignment="Center" Canvas.Left="217" Canvas.Top="331" />


            <PasswordBox x:Name="senhadigitar" Width="226" Height="28" Canvas.Left="193" Canvas.Top="391" HorizontalAlignment="Left" VerticalAlignment="Center" Padding="35,0,0,0" GotFocus="Senhadigitar_GotFocus" LostFocus="Senhadigitar_LostFocus"/>
            <Image Source="C:\Users\VINICIUSDASILVASAGIO\Desktop\aleatorio2\testone\65465456456\cadeadofechado.png" Canvas.Left="195" Canvas.Top="394" Height="23" Width="22" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" >
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="-1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>

            <TextBlock x:Name="senhablock" TextWrapping="Wrap" Opacity="0.5" FontSize="14"
                    IsHitTestVisible="False" TextAlignment="Center" Canvas.Left="217" Canvas.Top="396" HorizontalAlignment="Left" VerticalAlignment="Center" Width="51"><Run Language="pt-br" Text="Senha"/></TextBlock>
            <Button x:Name="cadastro" Content="Cadastro" Canvas.Left="193" Canvas.Top="455" Height="35" Width="82" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Center" Click="CADASTROBTN_Click" >
                <Button.Background>
                    <ImageBrush ImageSource="/botaocadastro.jpg"/>
                </Button.Background>
            </Button>

            <Button x:Name="LOGINBTN" Content="Login" HorizontalAlignment="Left" VerticalAlignment="Center" Height="35" Width="82" Foreground="White" Canvas.Left="288" Canvas.Top="455" Click="Logar">
                <Button.Background>
                    <ImageBrush ImageSource="/botaocadastro.jpg"/>
                </Button.Background>
            </Button>



        </Canvas>
    </Grid>
