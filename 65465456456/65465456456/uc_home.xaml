<UserControl x:Class="_65465456456.uc_home"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <Page 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Home"
      Background="#EEF3FB">

        <Page.Resources>

            <Style x:Key="MenuButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="48"/>
                <Setter Property="Margin" Value="8,4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="15,0"/>
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="Padding" Value="16"/>
            </Style>

        </Page.Resources>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Menu -->
            <Border Grid.Column="0" Background="#0A4BDE">

                <DockPanel>

                    <StackPanel Margin="15">

                        <TextBlock
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="10,20"><Run Language="pt-br" Text="Menu"/></TextBlock>

                        <Button x:Name="btninicio" Content="🏠  Início"
                            Style="{StaticResource MenuButtonStyle}"
                            Background="#2D68E8" FontSize="14"/>

                        <Button x:Name="btnalunos" Content="👨‍🎓  Alunos"
                            Style="{StaticResource MenuButtonStyle}" FontSize="14"/>

                        <Button x:Name="btnprofessores" Content="👨‍🏫  Professores"
                            Style="{StaticResource MenuButtonStyle}" FontSize="14"/>

                        <Button x:Name="btnturmas" Content="📚  Turmas"
                            Style="{StaticResource MenuButtonStyle}" FontSize="14"/>

                        <Button Content="📝  Notas"
                            Style="{StaticResource MenuButtonStyle}" FontSize="14"/>

                        <Button Content="📅  Agenda"
                            Style="{StaticResource MenuButtonStyle}" FontSize="14"/>

                        <Button Content="💰  Financeiro"
                            Style="{StaticResource MenuButtonStyle}" FontSize="14"/>

                        <Button Content="⚙  Configurações"
                            Style="{StaticResource MenuButtonStyle}" FontSize="14"/>

                    </StackPanel>

                </DockPanel>

            </Border>

            <!-- Conteúdo -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Background>
                    <ImageBrush ImageSource="/Fundohome.png"/>
                </ScrollViewer.Background>

                <StackPanel Margin="30">

                    <!-- Header -->
                    <Grid Margin="0,0,0,20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel/>

                        <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                            <Button Width="40" Height="40" Content="🔔"/>
                            <Button Width="40" Height="40" Margin="10,0,0,0" Content="👤"/>
                        </StackPanel>

                    </Grid>

                    <!-- Banner -->

                    <!-- Cards -->
                    <WrapPanel/>

                    <!-- Painéis -->
                    <Grid Margin="0,20,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                    </Grid>

                </StackPanel>

            </ScrollViewer>

        </Grid>

    </Page>




</UserControl>
