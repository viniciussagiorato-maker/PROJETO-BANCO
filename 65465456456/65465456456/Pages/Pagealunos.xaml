<UserControl x:Class="_65465456456.Pages.Pagealunos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid Background="#EEF3FB">

        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="25">

                <!-- Cabeçalho -->
                <Grid Margin="0,0,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="👨‍🎓 Gestão de Alunos"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#173B8F"/>

                        <TextBlock Text="Cadastre e acompanhe todos os alunos da escola"
                               Foreground="#666"
                               FontSize="14"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                        Content="+ Novo Aluno"
                        Height="45"
                        Width="150"
                        Background="#0A4BDE"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Cursor="Hand"/>
                </Grid>

                <!-- Cards Resumo -->
                <WrapPanel Margin="0,0,0,20">

                    <Border Style="{StaticResource CardStyle}"
                        Width="220"
                        Height="120">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="120"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#0A4BDE"
                                   HorizontalAlignment="Center"/>

                            <TextBlock Text="Alunos"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                        Width="220"
                        Height="120">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="8"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#0A4BDE"
                                   HorizontalAlignment="Center"/>

                            <TextBlock Text="Turmas"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                        Width="220"
                        Height="120">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="15"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#0A4BDE"
                                   HorizontalAlignment="Center"/>

                            <TextBlock Text="Novos este mês"
                                   FontSize="16"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                </WrapPanel>

                <!-- Pesquisa -->
                <Border Style="{StaticResource CardStyle}">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="🔍"
                               FontSize="18"
                               VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1"
                             BorderThickness="0"
                             FontSize="15"
                             VerticalContentAlignment="Center"
                             Text="Pesquisar aluno..."/>

                    </Grid>

                </Border>

                <!-- Lista de alunos -->
                <Border Style="{StaticResource CardStyle}"
                    Margin="8,20,8,8">

                    <StackPanel>

                        <TextBlock Text="Lista de Alunos"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>

                        <DataGrid x:Name="dgAlunos"
                              AutoGenerateColumns="False"
                              Height="400"
                              CanUserAddRows="False">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Código"
                                                Binding="{Binding Id}"
                                                Width="80"/>

                                <DataGridTextColumn Header="Nome"
                                                Binding="{Binding Nome}"
                                                Width="*"/>

                                <DataGridTextColumn Header="CPF"
                                                Binding="{Binding CPF}"
                                                Width="150"/>

                                <DataGridTextColumn Header="Turma"
                                                Binding="{Binding Turma}"
                                                Width="120"/>

                                <DataGridTextColumn Header="Telefone"
                                                Binding="{Binding Telefone}"
                                                Width="150"/>

                                <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                Width="100"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>
</UserControl>
