<UserControl x:Class="_65465456456.Pages.PageNotas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280" Background="{DynamicResource PageBackgroundBrush}">
    <Grid Margin="25" TextElement.Foreground="{DynamicResource PrimaryTextBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="📚 Gestão de Notas"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#1D4ED8"/>
            <TextBlock Text="Cadastre e acompanhe o desempenho dos alunos."
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Área de lançamento -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="18"
                    Padding="25"
                    Margin="0,0,15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Lançamento de Notas"
                               FontSize="22"
                               FontWeight="Bold"
                               Grid.ColumnSpan="3"
                               Margin="0,0,0,20"/>

                    <!-- ComboBox de Alunos -->
                    <StackPanel Grid.Row="1" Margin="8" Grid.ColumnSpan="3">
                        <TextBlock Text="Aluno"/>
                        <ComboBox x:Name="cmbAlunos" Height="40" DisplayMemberPath="Nome" SelectedValuePath="Id_aluno"/>
                    </StackPanel>

                    <!-- Disciplinas -->
                    <StackPanel Grid.Row="2" Margin="8">
                        <TextBlock Text="Matemática"/>
                        <TextBox x:Name="txtMatematica" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8">
                        <TextBlock Text="Português"/>
                        <TextBox x:Name="txtPortugues" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="8">
                        <TextBlock Text="Ciências"/>
                        <TextBox x:Name="txtCiencias" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="8">
                        <TextBlock Text="Inglês"/>
                        <TextBox x:Name="txtIngles" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8">
                        <TextBlock Text="Geografia"/>
                        <TextBox x:Name="txtGeografia" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="8">
                        <TextBlock Text="História"/>
                        <TextBox x:Name="txtHistoria" Height="40"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Painel lateral -->
            <StackPanel Grid.Column="1">
                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="18" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Média Geral" FontWeight="Bold"/>
                        <TextBlock x:Name="txtMediaGeral" Text="0,00" FontSize="42" FontWeight="Bold" Foreground="#1D4ED8" Margin="0,10"/>
                        <TextBlock Text="Situação"/>
                        <Border x:Name="borderSituacao" Background="#DCFCE7" CornerRadius="10" Padding="8" Margin="0,8">
                            <TextBlock x:Name="txtSituacao" Text="✔ Aprovado" Foreground="#15803D" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="18" Padding="20">
                    <StackPanel>
                        <Button Content="💾 Salvar"
                                Height="42"
                                Margin="0,0,0,10"
                                Background="#2563EB"
                                Foreground="White" Click="Button_Click"/>
                        <Button Content="✏ Atualizar" Height="42" Margin="0,0,0,10"/>
                        <Button Content="🗑 Limpar" Height="42"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Tabela -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}" CornerRadius="18" Padding="20">
            <StackPanel>
                <DockPanel Margin="0,0,0,15">
                    <Label Content="Buscar alunos" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="Buscanota" Width="650" Height="40" HorizontalAlignment="Left" TextChanged="pesquisaraluno" />
                </DockPanel>

                <DataGrid x:Name="DataGridnotas" Height="350" AutoGenerateColumns="False" RowHeight="50" HeadersVisibility="Column" RowHeaderWidth="0" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Aluno" Binding="{Binding Nome}" Width="220"/>
                        <DataGridTextColumn Header="Mat" Binding="{Binding Matematica}" Width="70"/>
                        <DataGridTextColumn Header="Port" Binding="{Binding Portugues}" Width="70"/>
                        <DataGridTextColumn Header="Ciên" Binding="{Binding Ciencias}" Width="70"/>
                        <DataGridTextColumn Header="Ing" Binding="{Binding Ingles}" Width="70"/>
                        <DataGridTextColumn Header="Geo" Binding="{Binding Geografia}" Width="70"/>
                        <DataGridTextColumn Header="Hist" Binding="{Binding Historia}" Width="70"/>
                        <DataGridTextColumn Header="Média" Binding="{Binding Media}" Width="70"/>
                        <DataGridTextColumn Header="Status" Width="*" Binding="{Binding status}"/>

                        <DataGridTemplateColumn Header="Editar"
    Width="80">

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <Button Content="✏"
                                                        Width="35"
                                                        Height="30"
                                                        Background="#3B82F6"
                                                        Foreground="White"
                                                        FontWeight="Bold" Click="exclunota" DataContext="{Binding}"
                                                        />
        
                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <!-- EXCLUIR -->

                        <DataGridTemplateColumn Header="Excluir"
                                             Width="80">

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <Button Content="🗑"
                                            Width="35"
                                            Height="30"
                                            Background="#EF4444"
                                            Foreground="White"
                                            FontWeight="Bold" Click="exclunota" DataContext="{Binding}"
                                            />

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>




                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
