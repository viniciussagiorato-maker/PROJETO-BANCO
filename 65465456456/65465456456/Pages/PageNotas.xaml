<UserControl x:Class="_65465456456.Pages.PageNotas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280" Background="#F3F6FB">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="📚 Gestão de Notas"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#1D4ED8"/>
            <TextBlock Text="Cadastre e acompanhe o desempenho dos alunos."
                       Foreground="Gray"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="18"
                    Padding="25"
                    Margin="0,0,15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Lançamento de Notas"
                               FontSize="22"
                               FontWeight="Bold"
                               Grid.ColumnSpan="3"
                               Margin="0,0,0,20"/>

                    <StackPanel Grid.Row="1" Margin="8">
                        <TextBlock Text="Aluno"/>
                        <ComboBox Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8">
                        <TextBlock Text="Turma"/>
                        <ComboBox Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="8">
                        <TextBlock Text="Bimestre"/>
                        <ComboBox Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="8">
                        <TextBlock Text="Matemática"/>
                        <TextBox Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8">
                        <TextBlock Text="Português"/>
                        <TextBox Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="8">
                        <TextBlock Text="Ciências"/>
                        <TextBox Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="8">
                        <TextBlock Text="Inglês"/>
                        <TextBox Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8">
                        <TextBlock Text="Geografia"/>
                        <TextBox Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="8">
                        <TextBlock Text="História"/>
                        <TextBox Height="40"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Background="White" CornerRadius="18" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Média Geral" FontWeight="Bold"/>
                        <TextBlock Text="8,75" FontSize="42" FontWeight="Bold" Foreground="#1D4ED8" Margin="0,10"/>
                        <TextBlock Text="Situação"/>
                        <Border Background="#DCFCE7" CornerRadius="10" Padding="8" Margin="0,8">
                            <TextBlock Text="✔ Aprovado" Foreground="#15803D" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="White" CornerRadius="18" Padding="20">
                    <StackPanel>
                        <Button Content="💾 Salvar"
                                Height="42"
                                Margin="0,0,0,10"
                                Background="#2563EB"
                                Foreground="White"/>
                        <Button Content="✏ Atualizar" Height="42" Margin="0,0,0,10"/>
                        <Button Content="🗑 Limpar" Height="42"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="18" Padding="20">
            <StackPanel>
                <DockPanel Margin="0,0,0,15">
                    <TextBox Width="641" Height="40"/>
                </DockPanel>

                <DataGrid Height="350" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Aluno" Width="220"/>
                        <DataGridTextColumn Header="Turma" Width="90"/>
                        <DataGridTextColumn Header="Mat" Width="60"/>
                        <DataGridTextColumn Header="Port" Width="60"/>
                        <DataGridTextColumn Header="Ciên" Width="60"/>
                        <DataGridTextColumn Header="Ing" Width="60"/>
                        <DataGridTextColumn Header="Geo" Width="60"/>
                        <DataGridTextColumn Header="Hist" Width="60"/>
                        <DataGridTextColumn Header="Média" Width="70"/>
                        <DataGridTextColumn Header="Situação" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
