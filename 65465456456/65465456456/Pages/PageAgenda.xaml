<UserControl x:Class="_65465456456.Pages.PageAgenda"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="25">

                <!-- CABEÇALHO -->
                <StackPanel Margin="0,0,0,20">

                    <TextBlock Text="📅 Agenda Escolar"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1D4ED8"/>

                    <TextBlock Text="Organize provas, reuniões, feriados e eventos da escola"
                           FontSize="15"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                </StackPanel>

                <!-- INDICADORES -->
                <UniformGrid Columns="4" Margin="0,0,0,20">

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Eventos este mês" Foreground="#6B7280"/>
                            <TextBlock x:Name="txtEventosMes"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Provas Agendadas" Foreground="#6B7280"/>
                            <TextBlock x:Name="txtProvas"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#DC2626"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Reuniões" Foreground="#6B7280"/>
                            <TextBlock x:Name="txtReunioes"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#F59E0B"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Próximo Evento" Foreground="#6B7280"/>
                            <TextBlock x:Name="txtProximoEvento"
                                       Text="—"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Foreground="#16A34A"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- CADASTRO -->
                <Border Style="{StaticResource CardStyle}"
                    Margin="0,0,0,20">

                    <StackPanel>

                        <TextBlock Text="Novo Evento"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- LINHA 1 -->

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Título"/>
                                <TextBox x:Name="agetitulo"
                                     Height="35"
                                     Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Tipo"/>

                                <ComboBox x:Name="cmbTipo"
                                      Height="35"
                                      Margin="0,5,0,0">

                                    <ComboBoxItem Content="Prova"/>
                                    <ComboBoxItem Content="Reunião"/>
                                    <ComboBoxItem Content="Feriado"/>
                                    <ComboBoxItem Content="Atividade"/>
                                    <ComboBoxItem Content="Evento"/>

                                </ComboBox>

                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="4">
                                <TextBlock Text="Turma"/>

                                <ComboBox x:Name="cmbTurmaEvento"
                                      Height="35"
                                      Margin="0,5,0,0"
                                      DisplayMemberPath="Nome_turma"
                                      SelectedValuePath="Id_turma"/>

                            </StackPanel>

                            <!-- LINHA 2 -->

                            <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,15,0,0">

                                <TextBlock Text="Data"/>

                                <DatePicker x:Name="dtData"
                                        Height="35"
                                        Margin="0,5,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,15,0,0">

                                <TextBlock Text="Hora (HH:mm)"/>

                                <TextBox x:Name="agehora"
                                     Height="35"
                                     Margin="0,5,0,0"/>

                            </StackPanel>

                            <!-- LINHA 3 -->

                            <StackPanel Grid.Row="2"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="5"
                                    Margin="0,15,0,0">

                                <TextBlock Text="Descrição"/>

                                <TextBox x:Name="agedescricao"
                                     Height="70"
                                     Margin="0,5,0,0"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"/>

                            </StackPanel>

                        </Grid>

                        <!-- BOTÕES -->

                        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,25,0,0">

                            <Button x:Name="btnCadastrar"
            Content="Adicionar Evento"
            Width="190"
            Height="42"
            Margin="0,0,10,0"
            Background="#1D4ED8"
            Foreground="White"
            FontWeight="Bold" Click="btnCadastrar_Click"
            />

                            <Button x:Name="btnLimpar"
            Content="Limpar Campos"
            Width="150"
            Height="42"
            Background="#E5E7EB"
            Foreground="#374151"
            FontWeight="Bold" Click="btnLimpar_Click"
            />

                        </StackPanel>

                    </StackPanel>

                </Border>

                <!-- PESQUISA -->

                <Border Style="{StaticResource CardStyle}"
        Margin="0,0,0,20">

                    <TextBox x:Name="txtPesquisar"
             Height="40"
             FontSize="15"
             VerticalContentAlignment="Center"
             Text="" TextChanged="pesquisarevento"/>

                </Border>

                <!-- LISTA -->

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Próximos Eventos"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                        <DataGrid x:Name="datagridagenda"
                  Height="320"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Data"
                                    Width="90"
                                    Binding="{Binding Data_evento, StringFormat=dd/MM/yyyy}"/>

                                <DataGridTextColumn Header="Hora"
                                    Width="70"
                                    Binding="{Binding Hora_evento}"/>

                                <DataGridTextColumn Header="Título"
                                    Width="200"
                                    Binding="{Binding Titulo}"/>

                                <DataGridTextColumn Header="Tipo"
                                    Width="110"
                                    Binding="{Binding Tipo}"/>

                                <DataGridTextColumn Header="Turma"
                                    Width="120"
                                    Binding="{Binding Turma}"/>

                                <DataGridTextColumn Header="Descrição"
                                    Width="*"
                                    Binding="{Binding Descricao}"/>

                                <!-- EDITAR -->

                                <DataGridTemplateColumn Header="Editar"
                     Width="80">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Button Content="✏"
                 Width="35"
                 Height="30"
                 Background="#3B82F6"
                 Foreground="White"
                 FontWeight="Bold"
                 Click="btnEditar_Click"
                 />

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                                <!-- EXCLUIR -->

                                <DataGridTemplateColumn Header="Excluir"
                     Width="80">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Button Content="🗑"
                 Width="35"
                 Height="30"
                 Background="#EF4444"
                 Foreground="White"
                 FontWeight="Bold"
                 Click="btnExcluir_Click"
                 />

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>


    </Grid>
</UserControl>
