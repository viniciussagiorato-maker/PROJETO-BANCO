<UserControl x:Class="_65465456456.Pages.PageProfessores"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid Background="#F3F6FB">
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="25">

                <!-- CABEÇALHO -->
                <StackPanel Margin="0,0,0,20">

                    <TextBlock Text="👨‍🏫 Gestão de Professores"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1D4ED8"/>

                    <TextBlock Text="Cadastre e acompanhe todos os professores da escola"
                           FontSize="15"
                           Foreground="#666666"/>

                </StackPanel>

                <!-- CADASTRO -->
                <Border Style="{StaticResource CardStyle}"
                    Margin="0,0,0,20">

                    <StackPanel>

                        <TextBlock Text="Cadastro de Professor"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- LINHA 1 -->

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Nome Completo"/>
                                <TextBox x:Name="pronome"
                                     Height="35"
                                     Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Email"/>
                                <TextBox x:Name="proemail"
                                     Height="35"
                                     Margin="0,5,0,0"/>
                            </StackPanel>
                            

                            <StackPanel Grid.Row="0" Grid.Column="4">
                                <TextBlock Text="CPF"/>
                                <TextBox x:Name="procpf"
                                     Height="35"
                                     Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- LINHA 2 -->

                            <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,15,0,0">

                                <TextBlock Text="Disciplina"/>

                                <ComboBox x:Name="cmbDisciplina"
                                      Height="35"
                                      Margin="0,5,0,0">

                                    <ComboBoxItem Content="Matemática"/>
                                    <ComboBoxItem Content="Português"/>
                                    <ComboBoxItem Content="História"/>
                                    <ComboBoxItem Content="Geografia"/>
                                    <ComboBoxItem Content="Ciências"/>
                                    <ComboBoxItem Content="Inglês"/>

                                </ComboBox>

                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,15,0,0">

                                <TextBlock><Run Language="pt-br" Text="Senha"/>
                                </TextBlock>
                                <PasswordBox x:Name="prosenha" Height="35" Margin="0,5,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                    Grid.Column="4"
                                    Margin="0,15,0,0">

                                <TextBlock Text="Formação"/>

                                <TextBox x:Name="proformacao"
                                     Height="35"
                                     Margin="0,5,0,0"/>

                            </StackPanel>

                        </Grid>

                        <!-- BOTÕES -->

                        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,25,0,0">

                            <Button x:Name="btnCadastrar"
            Content="Cadastrar Professor"
            Width="190"
            Height="42"
            Margin="0,0,10,0"
            Background="#1D4ED8"
            Foreground="White"
            FontWeight="Bold" Click="btnCadastrar_Click"
            />

                            <Button x:Name="btnLimpar"
            Content="Limpar Campos"
            Width="150"
            Height="42"
            Background="#E5E7EB"
            Foreground="#374151"
            FontWeight="Bold" Click="btnLimpar_Click"
            />

                        </StackPanel>

                    </StackPanel>

                </Border>

                <!-- PESQUISA -->

                <Border Style="{StaticResource CardStyle}"
        Margin="0,0,0,20">

                    <TextBox x:Name="txtPesquisar"
             Height="40"
             FontSize="15"
             VerticalContentAlignment="Center"
             Text="" TextChanged="pesquisaraluno"/>

                </Border>

                <!-- LISTA -->

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Lista de Professores"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                        <DataGrid x:Name="datagridpro"
                  Height="320"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Código"
                                    Width="80"
                                    Binding="{Binding Id_prof}"/>

                                <DataGridTextColumn Header="Nome"
                                    Width="220"
                                    Binding="{Binding Nome_prof}"/>

                                <DataGridTextColumn Header="Email"
                                    Width="220"
                                    Binding="{Binding Email}"/>

                                <DataGridTextColumn Header="CPF"
                                    Width="140"
                                    Binding="{Binding CPF}"/>

                                <DataGridTextColumn Header="Disciplina"
                                    Width="140"
                                    Binding="{Binding Disciplina}"/>

                                <DataGridTextColumn Header="Telefone"
                                    Width="140"
                                    Binding="{Binding Telefone}"/>

                                <DataGridTextColumn Header="Formação"
                                    Width="220"
                                    Binding="{Binding Formacao}"/>

                                <!-- EDITAR -->

                                <!-- EDITAR -->

                                <DataGridTemplateColumn Header="Editar"
                     Width="80">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Button Content="✏"
                 Width="35"
                 Height="30"
                 Background="#3B82F6"
                 Foreground="White"
                 FontWeight="Bold"
                 />

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                                <!-- EXCLUIR -->

                                <DataGridTemplateColumn Header="Excluir"
                     Width="80">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Button Content="🗑"
                 Width="35"
                 Height="30"
                 Background="#EF4444"
                 Foreground="White"
                 FontWeight="Bold"
                 />

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>


    </Grid>
</UserControl>
