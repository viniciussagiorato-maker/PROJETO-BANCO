<UserControl x:Class="_65465456456.Pages.Pageconfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">

    <Grid TextElement.Foreground="{DynamicResource PrimaryTextBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource PageBackgroundBrush}">

            <StackPanel Margin="20">

                <!-- TÍTULO -->
                <StackPanel Margin="0,0,0,20">

                    <TextBlock Text="⚙ Configurações do Sistema"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1D4ED8"/>

                    <TextBlock Text="Gerencie todas as configurações da escola"
                           FontSize="16"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                </StackPanel>

                <!-- CARDS -->
                <WrapPanel Margin="0,0,0,20">

                    <Border Width="180"
                        Height="100"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="15"
                        Margin="5">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🏫"
                                   FontSize="28"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="Geral"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <Border Width="180"
                        Height="100"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="15"
                        Margin="5">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="👥"
                                   FontSize="28"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="Usuários"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <Border Width="180"
                        Height="100"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="15"
                        Margin="5">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🔒"
                                   FontSize="28"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="Segurança"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <Border Width="180"
                        Height="100"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="15"
                        Margin="5">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🗄"
                                   FontSize="28"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="Banco"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <Border Width="180"
                        Height="100"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="15"
                        Margin="5">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="💾"
                                   FontSize="28"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="Backup"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                    <Border Width="180"
                        Height="100"
                        Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="15"
                        Margin="5">

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="🎨"
                                   FontSize="28"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="Aparência"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>

                    </Border>

                </WrapPanel>

                <!-- CONFIGURAÇÕES GERAIS -->
                <Expander Header="🏫 Configurações Gerais"
                      IsExpanded="True"
                      Margin="0,0,0,10">

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="10"
                        Padding="20">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Margin="10">
                                <TextBlock Text="Nome da Escola"/>
                                <TextBox Height="35"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                    Margin="10">
                                <TextBlock Text="Diretor"/>
                                <TextBox Height="35"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                    Margin="10">
                                <TextBlock Text="Telefone"/>
                                <TextBox Height="35"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="10">
                                <TextBlock Text="Email"/>
                                <TextBox Height="35"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    Margin="10">
                                <TextBlock Text="Endereço"/>
                                <TextBox Height="35"/>
                            </StackPanel>

                        </Grid>

                    </Border>

                </Expander>

                <!-- USUÁRIOS -->
                <Expander Header="👥 Usuários">

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="10"
                        Padding="20" >

                        <StackPanel>

                            <CheckBox Content="Permitir cadastro de novos usuários" />
                            <CheckBox Content="Permitir exclusão de registros"/>
                            <CheckBox Content="Permitir edição de notas"/>
                            <CheckBox Content="Permitir acesso ao financeiro"/>

                        </StackPanel>

                    </Border>

                </Expander>

                <!-- SEGURANÇA -->
                <Expander Header="🔒 Segurança"
                      Margin="0,10,0,0">

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="10"
                        Padding="20">

                        <StackPanel>

                            <TextBlock Text="Nova Senha"/>
                            <PasswordBox Height="35"/>

                            <TextBlock Text="Confirmar Senha"
                                   Margin="0,15,0,0"/>

                            <PasswordBox Height="35"/>

                            <CheckBox Content="Exigir senha forte"
                                  Margin="0,15,0,0"/>

                            <CheckBox Content="Bloquear após 3 tentativas"/>

                        </StackPanel>

                    </Border>

                </Expander>

                <!-- BANCO -->
                <Expander Header="🗄 Banco de Dados"
                      Margin="0,10,0,0">

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="10"
                        Padding="20">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="10">
                                <TextBlock Text="Servidor"/>
                                <TextBox Text="localhost"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                    Margin="10">
                                <TextBlock Text="Porta"/>
                                <TextBox Text="3306"/>
                            </StackPanel>

                            <StackPanel Grid.ColumnSpan="2"
                                    Margin="10,80,10,0">

                                <TextBlock Text="Banco"/>
                                <TextBox Text="escola"/>

                            </StackPanel>

                        </Grid>

                    </Border>

                </Expander>

                <!-- BACKUP -->
                <Expander Header="💾 Backup"
                      Margin="0,10,0,0">

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="10"
                        Padding="20">

                        <StackPanel>

                            <Button Content="Criar Backup"
                                Height="40"
                                Width="180"
                                Background="#1D4ED8"
                                Foreground="White"/>

                            <Button Content="Restaurar Backup"
                                Height="40"
                                Width="180"
                                Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                </Expander>

                <!-- APARÊNCIA -->
                <Expander Header="🎨 Aparência"
                      Margin="0,10,0,0">

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="10"
                        Padding="20">

                        <StackPanel>

                            <RadioButton x:Name="temaclaro" Content="Tema Claro"
                                     IsChecked="True"
                                     />

                            <RadioButton x:Name="temaescuro" Content="Tema Escuro"
                                     />

                            <RadioButton Content="Tema Azul"/>

                        </StackPanel>

                    </Border>

                </Expander>

                <!-- BOTÕES -->
                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,25">

                    <Button x:Name="salconfig" Content="Salvar Configurações"
                        Width="220"
                        Height="45"
                        Margin="5"
                        Background="#1D4ED8"
                        Foreground="White"
                        FontWeight="Bold" Click="tema_Checked" />

                    <Button Content="Restaurar Padrão"
                        Width="180"
                        Height="45"
                        Margin="5"/>

                </StackPanel>

            </StackPanel>

        </ScrollViewer>
    </Grid>
</UserControl>
