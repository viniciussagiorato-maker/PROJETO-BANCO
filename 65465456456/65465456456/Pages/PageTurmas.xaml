<UserControl x:Class="_65465456456.Pages.PageTurmas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="25">

                <!-- CABEÇALHO -->
                <StackPanel Margin="0,0,0,20">

                    <TextBlock Text="📚 Gestão de Turmas"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1D4ED8"/>

                    <TextBlock Text="Cadastre e acompanhe todas as turmas da escola"
                           FontSize="15"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                </StackPanel>

                <!-- INDICADORES -->
                <UniformGrid Columns="4" Margin="0,0,0,20">

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Total de Turmas" Foreground="#6B7280"/>
                            <TextBlock x:Name="txtTotalTurmas"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#2563EB"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Alunos Matriculados" Foreground="#6B7280"/>
                            <TextBlock x:Name="txtTotalAlunos"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#16A34A"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Turno Manhã" Foreground="#6B7280"/>
                            <TextBlock x:Name="txtTurnoManha"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#F59E0B"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Turno Tarde/Noite" Foreground="#6B7280"/>
                            <TextBlock x:Name="txtTurnoTarde"
                                       Text="0"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="#7C3AED"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- CADASTRO -->
                <Border Style="{StaticResource CardStyle}"
                    Margin="0,0,0,20">

                    <StackPanel>

                        <TextBlock Text="Cadastro de Turma"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- LINHA 1 -->

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Nome da Turma"/>
                                <TextBox x:Name="turnome"
                                     Height="35"
                                     Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Série/Ano"/>

                                <ComboBox x:Name="cmbSerie"
                                      Height="35"
                                      Margin="0,5,0,0">

                                    <ComboBoxItem Content="1º Ano"/>
                                    <ComboBoxItem Content="2º Ano"/>
                                    <ComboBoxItem Content="3º Ano"/>
                                    <ComboBoxItem Content="4º Ano"/>
                                    <ComboBoxItem Content="5º Ano"/>
                                    <ComboBoxItem Content="6º Ano"/>
                                    <ComboBoxItem Content="7º Ano"/>
                                    <ComboBoxItem Content="8º Ano"/>
                                    <ComboBoxItem Content="9º Ano"/>

                                </ComboBox>

                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="4">
                                <TextBlock Text="Turno"/>

                                <ComboBox x:Name="cmbTurno"
                                      Height="35"
                                      Margin="0,5,0,0">

                                    <ComboBoxItem Content="Manhã"/>
                                    <ComboBoxItem Content="Tarde"/>
                                    <ComboBoxItem Content="Noite"/>

                                </ComboBox>

                            </StackPanel>

                            <!-- LINHA 2 -->

                            <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,15,0,0">

                                <TextBlock Text="Sala"/>

                                <TextBox x:Name="tursala"
                                     Height="35"
                                     Margin="0,5,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,15,0,0">

                                <TextBlock Text="Capacidade (vagas)"/>

                                <TextBox x:Name="turcapacidade"
                                     Height="35"
                                     Margin="0,5,0,0"/>

                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                    Grid.Column="4"
                                    Margin="0,15,0,0">

                                <TextBlock Text="Professor Responsável"/>

                                <ComboBox x:Name="cmbProfessor"
                                      Height="35"
                                      Margin="0,5,0,0"
                                      DisplayMemberPath="Nome_prof"
                                      SelectedValuePath="Id_prof"/>

                            </StackPanel>

                        </Grid>

                        <!-- BOTÕES -->

                        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,25,0,0">

                            <Button x:Name="btnCadastrar"
            Content="Cadastrar Turma"
            Width="190"
            Height="42"
            Margin="0,0,10,0"
            Background="#1D4ED8"
            Foreground="White"
            FontWeight="Bold" Click="btnCadastrar_Click"
            />

                            <Button x:Name="btnLimpar"
            Content="Limpar Campos"
            Width="150"
            Height="42"
            Background="#E5E7EB"
            Foreground="#374151"
            FontWeight="Bold" Click="btnLimpar_Click"
            />

                        </StackPanel>

                    </StackPanel>

                </Border>

                <!-- PESQUISA -->

                <Border Style="{StaticResource CardStyle}"
        Margin="0,0,0,20">

                    <TextBox x:Name="txtPesquisar"
             Height="40"
             FontSize="15"
             VerticalContentAlignment="Center"
             Text="" TextChanged="pesquisarturma"/>

                </Border>

                <!-- LISTA -->

                <Border Style="{StaticResource CardStyle}">

                    <StackPanel>

                        <TextBlock Text="Lista de Turmas"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                        <DataGrid x:Name="datagridturmas"
                  Height="320"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Código"
                                    Width="80"
                                    Binding="{Binding Id_turma}"/>

                                <DataGridTextColumn Header="Turma"
                                    Width="160"
                                    Binding="{Binding Nome_turma}"/>

                                <DataGridTextColumn Header="Série"
                                    Width="100"
                                    Binding="{Binding Serie}"/>

                                <DataGridTextColumn Header="Turno"
                                    Width="100"
                                    Binding="{Binding Turno}"/>

                                <DataGridTextColumn Header="Sala"
                                    Width="90"
                                    Binding="{Binding Sala}"/>

                                <DataGridTextColumn Header="Vagas"
                                    Width="80"
                                    Binding="{Binding Capacidade}"/>

                                <DataGridTextColumn Header="Professor Responsável"
                                    Width="220"
                                    Binding="{Binding Professor}"/>

                                <!-- EDITAR -->

                                <DataGridTemplateColumn Header="Editar"
                     Width="80">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Button Content="✏"
                 Width="35"
                 Height="30"
                 Background="#3B82F6"
                 Foreground="White"
                 FontWeight="Bold"
                 Click="btnEditar_Click"
                 />

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                                <!-- EXCLUIR -->

                                <DataGridTemplateColumn Header="Excluir"
                     Width="80">

                                    <DataGridTemplateColumn.CellTemplate>

                                        <DataTemplate>

                                            <Button Content="🗑"
                 Width="35"
                 Height="30"
                 Background="#EF4444"
                 Foreground="White"
                 FontWeight="Bold"
                 Click="btnExcluir_Click"
                 />

                                        </DataTemplate>

                                    </DataGridTemplateColumn.CellTemplate>

                                </DataGridTemplateColumn>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>


    </Grid>
</UserControl>
