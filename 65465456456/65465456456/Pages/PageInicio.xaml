<UserControl x:Class="_65465456456.Pages.PageInicio"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:_65465456456.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1280">
    <Grid>
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Background>
                <ImageBrush ImageSource="/Fundohome.png"/>
            </ScrollViewer.Background>

            <StackPanel Margin="30">

                <!-- Header -->
                <Grid Margin="0,0,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Bem-vindo de volta!"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#173B8F"/>

                        <TextBlock Text="Painel principal do sistema escolar"
                           Foreground="#666"
                           Margin="0,5,0,0" FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                        <Button Width="40" Height="40" Content="🔔"/>
                        <Button Width="40" Height="40" Margin="10,0,0,0" Content="👤"/>
                    </StackPanel>

                </Grid>

                <!-- Banner -->
                <Border Height="220"
                Background="White"
                CornerRadius="20"
                Margin="0,0,0,20">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="350"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center"
                            Margin="30">

                            <TextBlock Text="Sistema Escolar"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#0A4BDE" HorizontalAlignment="Center"/>

                            <TextBlock Text="Gerencie alunos, turmas, notas e atividades em um único lugar."
                               Margin="0,15,0,0"
                               TextWrapping="Wrap"
                               Width="450" FontSize="14" HorizontalAlignment="Center"/>

                        </StackPanel>

                        <!-- Substitua pela sua imagem -->
                        <Border Grid.Column="1"
                        Margin="71,12,71,12"
                        CornerRadius="15">
                            <Border.Background>
                                <ImageBrush ImageSource="/logohome.png"/>
                            </Border.Background>
                        </Border>

                    </Grid>

                </Border>

                <!-- Cards -->
                <WrapPanel>

                    <Border Width="220" Height="140" Style="{StaticResource CardStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="👨‍🎓" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="Alunos" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Width="220" Height="140" Style="{StaticResource CardStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📚" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="Turmas" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Width="220" Height="140" Style="{StaticResource CardStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📝" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="Notas" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Width="220" Height="140" Style="{StaticResource CardStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="📅" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="Agenda" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>

                <!-- Painéis -->
                <Grid Margin="0,20,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,10,0">

                        <StackPanel>
                            <TextBlock Text="Últimas Atividades"
                               FontSize="20"
                               FontWeight="Bold"/>
                            <Separator Margin="0,10"/>
                            <TextBlock Text="• Novo aluno cadastrado" FontSize="14"/>
                            <TextBlock Text="• Turma A atualizada" FontSize="14"/>
                            <TextBlock Text="• Agenda semanal criada" FontSize="14"/>
                            <TextBlock Text="• Boletim publicado" FontSize="14"/>
                        </StackPanel>

                    </Border>

                    <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="16"
                    Padding="20">

                        <StackPanel>
                            <TextBlock Text="Resumo Geral"
                               FontSize="20"
                               FontWeight="Bold"/>
                            <Separator Margin="0,10"/>

                            <TextBlock x:Name="blockalunos" Text="Alunos: 120" Margin="0,8" FontSize="14"/>
                            <TextBlock x:Name="blockturma" Text="Turmas: 8" Margin="0,8" FontSize="14"/>
                            <TextBlock x:Name="blockprof" Text="Professores: 15" Margin="0,8" FontSize="14"/>
                            <TextBlock x:Name="blockferiados" Text="Feriados: 4" Margin="0,8" FontSize="14"/>
                        </StackPanel>

                    </Border>

                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
